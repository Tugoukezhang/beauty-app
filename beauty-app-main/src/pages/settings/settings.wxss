/* 设置页面样式 */
.settings-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 0;
}

/* 分组 */
.section {
  background: #fff;
  margin-bottom: 24rpx;
}

.section-title {
  padding: 24rpx 32rpx 16rpx;
  font-size: 26rpx;
  color: #999;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item.no-border {
  border-bottom: none;
}

.item-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.item-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #ccc;
  border-right: 2rpx solid #ccc;
  transform: rotate(45deg);
}

/* 退出登录 */
.logout-section {
  padding: 48rpx 32rpx;
}

.logout-btn {
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}
