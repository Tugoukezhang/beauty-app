/* 任务中心样式 */
.task-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 资产卡片 */
.assets-card {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  padding: 40rpx 30rpx;
}

.assets-header {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 40rpx;
}

.asset-item {
  display: flex;
  align-items: center;
}

.asset-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 16rpx;
}

.asset-info {
  display: flex;
  flex-direction: column;
}

.asset-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.asset-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.asset-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 签到区域 */
.signin-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
}

.signin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.signin-title {
  font-size: 28rpx;
  color: #fff;
}

.signin-days {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  margin: 0 8rpx;
}

.signin-reward {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 215, 0, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.signin-btn {
  background: #fff;
  color: #FF6B9D;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.signin-btn.signed {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
}

.signin-btn::after {
  display: none;
}

/* 日历 */
.calendar-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-month {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.calendar-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-weekday {
  width: 14.285%;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 16rpx 0;
}

.calendar-day {
  width: 14.285%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-number {
  font-size: 24rpx;
  color: #fff;
}

.calendar-day.signed .day-number {
  color: #FFD700;
}

.calendar-day.today {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.calendar-day.future .day-number {
  color: rgba(255, 255, 255, 0.4);
}

.sign-icon {
  width: 20rpx;
  height: 20rpx;
  position: absolute;
  bottom: 8rpx;
}

/* 任务区域 */
.task-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.task-item.completed {
  background: #f0f9ff;
}

.task-item.claimed {
  background: #f5f5f5;
  opacity: 0.7;
}

.task-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.task-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4EC 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.task-icon {
  width: 44rpx;
  height: 44rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.task-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  width: 120rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border-radius: 4rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #FF6B9D;
}

.task-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.task-reward {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.reward-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.reward-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B9D;
}

.task-btn {
  min-width: 120rpx;
  padding: 16rpx 28rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  line-height: 1;
}

.task-btn.pending {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
}

.task-btn.completed {
  background: #4CAF50;
  color: #fff;
}

.task-btn.claimed {
  background: #ccc;
  color: #999;
}

.task-btn::after {
  display: none;
}

/* 累计奖励 */
.total-reward {
  text-align: center;
  padding: 30rpx;
}

.reward-text {
  font-size: 26rpx;
  color: #666;
}

/* 提示 */
.task-tips {
  background: #fff;
  margin: 0 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}
