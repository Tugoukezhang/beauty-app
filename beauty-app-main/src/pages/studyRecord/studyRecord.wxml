<view class="study-record-container">
  <!-- 空状态 -->
  <view class="empty" wx:if="{{empty && !loading}}">
    <image class="empty-icon" src="/assets/images/empty-study.png" mode="aspectFit" />
    <text class="empty-text">暂无学习记录</text>
    <text class="empty-hint">快去学习课程吧</text>
  </view>

  <!-- 学习记录列表 -->
  <view class="record-list" wx:else>
    <view
      class="record-item"
      wx:for="{{recordList}}"
      wx:key="id"
    >
      <!-- 课程封面 -->
      <view class="record-cover" data-course-id="{{item.courseId}}" data-id="{{item.id}}" bindtap="continueStudy">
        <image class="cover-img" src="{{item.cover}}" mode="aspectFill" />
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress}}%"></view>
        </view>
        <view class="progress-text" wx:if="{{item.progress === 100}}">已完成</view>
      </view>

      <!-- 课程信息 -->
      <view class="record-info">
        <view class="course-title" data-course-id="{{item.courseId}}" data-id="{{item.id}}" bindtap="continueStudy">
          {{item.courseTitle}}
        </view>
        <view class="course-teacher">{{item.teacher}}</view>
        <view class="record-meta">
          <text class="last-chapter">上次学到：{{item.lastChapter}}</text>
          <text class="last-time">{{item.lastTime}}</text>
        </view>
        <view class="chapter-progress">
          {{item.completedChapters}}/{{item.totalChapters}}章节
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="record-actions">
        <view
          class="continue-btn"
          data-course-id="{{item.courseId}}"
          data-id="{{item.id}}"
          bindtap="continueStudy"
        >
          {{item.progress === 100 ? '复习' : '继续'}}
        </view>
        <view
          class="delete-btn"
          data-id="{{item.id}}"
          catchtap="deleteRecord"
        >
          删除
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
