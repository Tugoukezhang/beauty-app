<!--
  i妆 - 首页（沉浸式化妆台）
  设计理念：只有人物+化妆台+入口，极致干净
  推荐课程在"课程"Tab，热门动态在"社区"Tab
-->
<view class="home-page">

  <!-- ====== 顶部栏 ====== -->
  <view class="top-bar">
    <view class="logo-area">
      <text class="logo-text">i妆</text>
    </view>
    <view class="top-actions">
      <view class="top-btn" bindtap="onSearchTap">
        <text class="top-icon">🔍</text>
      </view>
      <view class="top-btn" bindtap="goToMessages">
        <text class="top-icon">🔔</text>
        <view class="dot-badge" wx:if="{{hasNewMessage}}"></view>
      </view>
    </view>
  </view>

  <!-- ====== 化妆台主场景 ====== -->
  <view class="vanity-scene">

    <!-- 装饰粒子 -->
    <view class="particles">
      <view class="particle p1">✨</view>
      <view class="particle p2">🌸</view>
      <view class="particle p3">💫</view>
      <view class="particle p4">🎀</view>
    </view>

    <!-- 2D人物（镜子外，站在桌前） -->
    <view class="character-area">
      <view class="avatar-character" bindtap="goToAvatarCustomize">
        <!-- 头发 -->
        <view class="avatar-hair {{avatar.hairStyle}}"></view>
        <!-- 发饰 -->
        <view class="avatar-accessory {{avatar.accessory}}" wx:if="{{avatar.accessory}}"></view>
        <!-- 脸 -->
        <view class="avatar-face">
          <view class="avatar-eyes">
            <view class="avatar-eye left"></view>
            <view class="avatar-eye right"></view>
          </view>
          <view class="avatar-blush left"></view>
          <view class="avatar-blush right"></view>
          <view class="avatar-mouth"></view>
        </view>
        <!-- 身体/衣服 -->
        <view class="avatar-dress {{avatar.dressStyle}}"></view>
        <!-- 手持物品 -->
        <view class="avatar-hand-item {{avatar.handItem}}" wx:if="{{avatar.handItem}}"></view>
        <!-- 换装提示 -->
        <view class="customize-hint">
          <text class="hint-icon">👗</text>
          <text class="hint-text">换装</text>
        </view>
      </view>
    </view>

    <!-- 化妆台桌面 -->
    <view class="vanity-desk">
      <!-- 镜子（装饰） -->
      <view class="desk-mirror">
        <view class="mirror-frame">
          <view class="mirror-surface">
            <view class="mirror-glow"></view>
          </view>
        </view>
      </view>

      <!-- 化妆品+入口 -->
      <view class="desk-items">
        <view class="desk-item" bindtap="goToThemeMakeup">
          <view class="item-icon lipstick-icon">
            <view class="lipstick-cap"></view>
            <view class="lipstick-body"></view>
          </view>
          <text class="item-text">主题妆</text>
        </view>

        <view class="desk-item" bindtap="goToCourseList">
          <view class="item-icon palette-icon">
            <view class="palette-base">
              <view class="palette-dot d1"></view>
              <view class="palette-dot d2"></view>
              <view class="palette-dot d3"></view>
            </view>
          </view>
          <text class="item-text">课程</text>
        </view>

        <view class="desk-item" bindtap="goToCommunity">
          <view class="item-icon perfume-icon">
            <view class="perfume-nozzle"></view>
            <view class="perfume-bottle"></view>
          </view>
          <text class="item-text">玩法</text>
        </view>

        <view class="desk-item" bindtap="goToShop">
          <view class="item-icon cream-icon">
            <view class="cream-lid"></view>
            <view class="cream-jar"></view>
          </view>
          <text class="item-text">商城</text>
        </view>

        <view class="desk-item" bindtap="goToMirror">
          <view class="item-icon mirror-icon">
            <view class="mirror-mini"></view>
          </view>
          <text class="item-text">补光镜</text>
        </view>
      </view>
    </view>

    <!-- 每日一句 -->
    <view class="daily-quote">
      <text class="quote-text">{{dailyQuote.text}}</text>
    </view>
  </view>

  <!-- 每日任务提醒（小巧） -->
  <view class="daily-task-bar" bindtap="goToTask" wx:if="{{showDailyTask}}">
    <text class="task-icon">🎯</text>
    <text class="task-text">完成今日任务领10妆币</text>
    <text class="task-go">›</text>
  </view>

</view>
