/**
 * i妆 - 首页样式（沉浸式化妆台 - 精简版）
 * 只有：人物 + 化妆台 + 入口
 */

.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFE8F0 30%, #FDE2EE 60%, #F8F4F6 100%);
  display: flex;
  flex-direction: column;
}

/* ========== 顶部栏 ========== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 36rpx;
  position: relative;
  z-index: 10;
}

.logo-text {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B9D, #FF3D7F);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 2rpx;
}

.top-actions {
  display: flex;
  gap: 20rpx;
}

.top-btn {
  width: 68rpx;
  height: 68rpx;
  background: rgba(255,255,255,0.65);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  position: relative;
}

.top-icon {
  font-size: 34rpx;
}

.dot-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 14rpx;
  height: 14rpx;
  background: #FF3D7F;
  border-radius: 50%;
  border: 2rpx solid #FFF5F8;
}

/* ========== 化妆台主场景 ========== */
.vanity-scene {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  overflow: hidden;
}

/* 装饰粒子 */
.particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.particle {
  position: absolute;
  font-size: 28rpx;
}

.p1 { top: 8%; left: 12%; animation: floatA 5s ease-in-out infinite; }
.p2 { top: 15%; right: 15%; animation: floatB 6s ease-in-out infinite 1s; }
.p3 { top: 35%; left: 8%; animation: floatA 4s ease-in-out infinite 2s; }
.p4 { top: 40%; right: 10%; animation: floatB 7s ease-in-out infinite 0.5s; }

@keyframes floatA {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.7; }
  50% { transform: translateY(-20rpx) rotate(10deg); opacity: 1; }
}

@keyframes floatB {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
  50% { transform: translateY(-16rpx) rotate(-8deg); opacity: 1; }
}

/* ========== 2D人物 ========== */
.character-area {
  position: relative;
  z-index: 5;
  margin-bottom: 20rpx;
}

.avatar-character {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: charBreathe 3s ease-in-out infinite;
}

@keyframes charBreathe {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* 换装提示 */
.customize-hint {
  position: absolute;
  right: -20rpx;
  top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.85);
  border-radius: 20rpx;
  padding: 8rpx 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.2);
  animation: hintPulse 2s ease-in-out infinite;
}

@keyframes hintPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 18rpx;
  color: #FF6B9D;
  font-weight: 600;
}

/* 头发 */
.avatar-hair {
  width: 130rpx;
  height: 90rpx;
  background: linear-gradient(180deg, #5C3A2E 0%, #3A1C1A 100%);
  border-radius: 50% 50% 35% 35%;
  position: relative;
  z-index: 3;
}

/* 长发 */
.avatar-hair.long {
  width: 150rpx;
  height: 180rpx;
  border-radius: 50% 50% 20% 20%;
}

/* 双马尾 */
.avatar-hair.twintail::before,
.avatar-hair.twintail::after {
  content: '';
  position: absolute;
  width: 30rpx;
  height: 100rpx;
  background: linear-gradient(180deg, #5C3A2E, #3A1C1A);
  border-radius: 40%;
  top: 30rpx;
}

.avatar-hair.twintail::before { left: -10rpx; }
.avatar-hair.twintail::after { right: -10rpx; }

/* 发饰 */
.avatar-accessory {
  position: absolute;
  top: 20rpx;
  right: 10rpx;
  z-index: 4;
}

.avatar-accessory.bow {
  width: 30rpx;
  height: 24rpx;
  background: #FF6B9D;
  border-radius: 50% 50% 0 50%;
  box-shadow: 0 0 0 6rpx rgba(255, 107, 157, 0.2);
}

.avatar-accessory.crown {
  width: 40rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #FFD700, #FFA500);
  clip-path: polygon(0% 100%, 15% 30%, 30% 80%, 50% 0%, 70% 80%, 85% 30%, 100% 100%);
}

.avatar-accessory.flower {
  font-size: 30rpx;
}

/* 脸 */
.avatar-face {
  width: 100rpx;
  height: 110rpx;
  background: linear-gradient(180deg, #FFE0CC 0%, #FFD4B8 100%);
  border-radius: 42% 42% 38% 38%;
  position: relative;
  z-index: 3;
  margin-top: -24rpx;
}

/* 眼睛 */
.avatar-eyes {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding-top: 30rpx;
}

.avatar-eye {
  width: 16rpx;
  height: 22rpx;
  background: #3A1C1A;
  border-radius: 50%;
  position: relative;
  animation: blink 4s ease-in-out infinite;
}

@keyframes blink {
  0%, 95%, 100% { transform: scaleY(1); }
  97% { transform: scaleY(0.1); }
}

.avatar-eye::after {
  content: '';
  position: absolute;
  top: 4rpx;
  right: 2rpx;
  width: 6rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 50%;
}

/* 腮红 */
.avatar-blush {
  position: absolute;
  width: 18rpx;
  height: 12rpx;
  background: rgba(255, 130, 160, 0.45);
  border-radius: 50%;
  top: 54rpx;
}

.avatar-blush.left { left: 8rpx; }
.avatar-blush.right { right: 8rpx; }

/* 嘴巴 */
.avatar-mouth {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 8rpx;
  background: #FF8FAA;
  border-radius: 0 0 50% 50%;
}

/* 衣服 */
.avatar-dress {
  width: 120rpx;
  height: 80rpx;
  background: linear-gradient(180deg, #FF6B9D 0%, #FF3D7F 100%);
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -10rpx;
  position: relative;
  z-index: 2;
}

/* 衣服样式变化 */
.avatar-dress.princess {
  width: 140rpx;
  height: 120rpx;
  border-radius: 30% 30% 0 0;
  background: linear-gradient(180deg, #FF6B9D, #FF3D7F, #E0245E);
}

.avatar-dress.ancient {
  width: 150rpx;
  height: 130rpx;
  border-radius: 20rpx 20rpx 50% 50%;
  background: linear-gradient(180deg, #FFD700, #FF8C00);
}

.avatar-dress.cos {
  width: 130rpx;
  height: 100rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: linear-gradient(180deg, #9B59B6, #8E44AD);
}

/* 手持物品 */
.avatar-hand-item {
  position: absolute;
  bottom: 20rpx;
  right: -30rpx;
  z-index: 6;
}

.avatar-hand-item.lipstick {
  width: 16rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #FF3D7F, #CC0044);
  border-radius: 4rpx;
}

.avatar-hand-item.brush {
  width: 8rpx;
  height: 44rpx;
  background: linear-gradient(180deg, #D4A8BA, #8B6E7A);
  border-radius: 2rpx;
}

/* ========== 化妆台桌面 ========== */
.vanity-desk {
  position: relative;
  z-index: 5;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 镜子装饰 */
.desk-mirror {
  margin-bottom: 24rpx;
}

.mirror-frame {
  width: 200rpx;
  height: 260rpx;
  background: linear-gradient(180deg, #E8C4D0, #C4909E);
  border-radius: 50% 50% 12rpx 12rpx;
  padding: 6rpx;
  box-shadow: 0 8rpx 24rpx rgba(180, 120, 150, 0.25);
}

.mirror-surface {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(255,245,248,0.6), rgba(255,232,240,0.3));
  border-radius: 50% 50% 8rpx 8rpx;
  position: relative;
  overflow: hidden;
}

.mirror-glow {
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  width: 50rpx;
  height: 80rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.5), rgba(255,255,255,0));
  border-radius: 50%;
  transform: rotate(-20deg);
}

/* 桌面物品入口 */
.desk-items {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 28rpx 20rpx;
  width: 100%;
}

.desk-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: transform 0.2s;
}

.desk-item:active {
  transform: scale(0.92);
}

.item-icon {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  backdrop-filter: blur(8px);
  box-shadow: 0 4rpx 16rpx rgba(180, 120, 150, 0.12);
}

.item-text {
  font-size: 22rpx;
  color: #9C7A8A;
  font-weight: 500;
}

/* 口红图标 */
.lipstick-cap {
  width: 20rpx;
  height: 10rpx;
  background: #D4A8BA;
  border-radius: 3rpx 3rpx 0 0;
}

.lipstick-body {
  width: 16rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #FF3D7F, #CC0044);
  border-radius: 0 0 3rpx 3rpx;
}

/* 眼影盘图标 */
.palette-base {
  width: 40rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #8B5E3C, #6B3E1C);
  border-radius: 6rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 4rpx;
}

.palette-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.palette-dot.d1 { background: #FF6B9D; }
.palette-dot.d2 { background: #FFB347; }
.palette-dot.d3 { background: #87CEEB; }

/* 香水图标 */
.perfume-nozzle {
  width: 10rpx;
  height: 6rpx;
  background: #D4A8BA;
  border-radius: 2rpx;
  margin-bottom: 2rpx;
}

.perfume-bottle {
  width: 28rpx;
  height: 34rpx;
  background: linear-gradient(180deg, #F0C8D8, #E0A8C0);
  border-radius: 4rpx;
}

/* 面霜图标 */
.cream-lid {
  width: 30rpx;
  height: 8rpx;
  background: #F0E0D0;
  border-radius: 4rpx 4rpx 0 0;
}

.cream-jar {
  width: 30rpx;
  height: 22rpx;
  background: linear-gradient(180deg, #FFF5E8, #FFE8CC);
  border-radius: 0 0 6rpx 6rpx;
}

/* 小镜子图标 */
.mirror-mini {
  width: 28rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #F0F0F0, #E8E8E8);
  border: 3rpx solid #D4A8BA;
  border-radius: 50% 50% 4rpx 4rpx;
  position: relative;
}

.mirror-mini::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 8rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 50%;
}

/* ========== 每日一句 ========== */
.daily-quote {
  text-align: center;
  padding: 24rpx 60rpx 20rpx;
  z-index: 5;
}

.quote-text {
  font-size: 24rpx;
  color: #C4909E;
  font-style: italic;
  line-height: 1.6;
}

/* ========== 每日任务条 ========== */
.daily-task-bar {
  display: flex;
  align-items: center;
  margin: 16rpx 30rpx 30rpx;
  padding: 18rpx 28rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 40rpx;
  backdrop-filter: blur(8px);
  box-shadow: 0 4rpx 16rpx rgba(180, 120, 150, 0.1);
}

.task-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.task-text {
  flex: 1;
  font-size: 24rpx;
  color: #9C7A8A;
}

.task-go {
  font-size: 32rpx;
  color: #FF6B9D;
  font-weight: 700;
}
