/* 搜索页面样式 */
.search-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.clear-btn {
  color: #999;
  font-size: 36rpx;
  padding: 8rpx;
}

.cancel-btn {
  color: #666;
  font-size: 28rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 搜索引导 */
.search-guide {
  padding: 24rpx;
}

/* 历史/热门 */
.guide-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-header .clear-btn {
  font-size: 26rpx;
  color: #999;
}

/* 历史词 */
.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keyword-item {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.delete-icon {
  color: #999;
  font-size: 28rpx;
}

/* 热门搜索 */
.hot-list {
  display: flex;
  flex-direction: column;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  width: 40rpx;
  height: 40rpx;
  background: #f0f0f0;
  color: #999;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.hot-rank.top {
  background: linear-gradient(135deg, #FF6B9D, #FFB6C1);
  color: #fff;
}

.hot-content {
  flex: 1;
  margin-left: 16rpx;
}

.hot-keyword {
  font-size: 28rpx;
  color: #333;
}

.hot-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 搜索结果 */
.search-result {
  padding: 24rpx;
}

.loading {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 结果列表 */
.result-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.result-cover {
  width: 200rpx;
  height: 130rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-teacher {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.result-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.result-price {
  font-size: 32rpx;
  color: #FF6B9D;
  font-weight: 600;
}

.result-free {
  font-size: 26rpx;
  color: #07C160;
}

.result-stats {
  font-size: 24rpx;
  color: #999;
}
