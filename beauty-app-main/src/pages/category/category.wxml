<view class="category-container">
  <!-- 顶部搜索栏 -->
  <view class="search-header">
    <view class="search-box" bindtap="onSearchTap">
      <view class="search-icon">
        <view class="search-circle"></view>
        <view class="search-handle"></view>
      </view>
      <text class="search-placeholder">搜索课程、老师...</text>
    </view>
  </view>

  <!-- 左侧分类列表 -->
  <scroll-view class="category-left" scroll-y="true">
    <view class="category-fixed">
      <view class="search-box-mini" bindtap="onSearchTap">
        <view class="search-icon-mini">
          <view class="search-circle-sm"></view>
          <view class="search-handle-sm"></view>
        </view>
      </view>
    </view>
    <view
      class="category-item {{item.id === activeCategoryId ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onCategoryTap"
    >
      <view class="category-indicator"></view>
      <text class="category-name">{{item.name}}</text>
      <view class="category-count" wx:if="{{item.count}}">{{item.count}}</view>
    </view>
  </scroll-view>

  <!-- 右侧内容区 -->
  <scroll-view class="category-right" scroll-y="true">
    <!-- 筛选排序区 -->
    <view class="filter-wrapper">
      <!-- 主筛选栏 -->
      <view class="filter-main">
        <view
          class="filter-btn {{item.id === sortBy ? 'active' : ''}}"
          wx:for="{{mainFilters}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onFilterTap"
        >
          {{item.name}}
        </view>
        <!-- 价格筛选 -->
        <view class="filter-btn price-btn {{sortBy === 'price_asc' || sortBy === 'price_desc' ? 'active' : ''}}" bindtap="togglePriceFilter">
          <text>价格</text>
          <view class="price-arrow {{sortBy === 'price_desc' ? 'desc' : ''}}">
            <view class="arrow-up {{sortBy === 'price_asc' ? 'active' : ''}}"></view>
            <view class="arrow-down {{sortBy === 'price_desc' ? 'active' : ''}}"></view>
          </view>
        </view>
      </view>
      <!-- 查看全部 -->
      <view class="view-all" bindtap="viewAll">
        <text>查看全部</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 课程列表 -->
    <view class="course-section">
      <view class="section-title">
        <view class="title-left">
          <view class="title-icon"></view>
          <text>热门课程</text>
        </view>
        <text class="course-count" wx:if="{{courses.length > 0}}">共{{courses.length}}门</text>
      </view>
      <view class="course-list">
        <view
          class="course-item"
          wx:for="{{courses}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goToCourse"
        >
          <image class="course-cover" src="{{item.cover}}" mode="aspectFill" />
          <!-- 免费标签 -->
          <view class="free-tag" wx:if="{{item.isFree}}">免费</view>
          <view class="course-info">
            <view class="course-title">{{item.title}}</view>
            <view class="course-teacher">{{item.teacher}}</view>
            <view class="course-footer">
              <view class="course-price">
                <text class="price" wx:if="{{!item.isFree}}">¥{{item.price}}</text>
                <text class="free" wx:if="{{item.isFree}}">免费</text>
                <text class="original" wx:if="{{!item.isFree && item.originalPrice > item.price}}">¥{{item.originalPrice}}</text>
              </view>
              <view class="course-stats">
                <text class="rating">★ {{item.rating}}</text>
                <text class="count">{{item.studyCount}}人在学</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态提示 -->
    <view class="empty-tip" wx:if="{{courses.length === 0 && !loading}}">
      <view class="empty-icon">📚</view>
      <text>暂无相关课程</text>
      <text class="empty-hint">看看其他分类吧</text>
    </view>
  </scroll-view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>
