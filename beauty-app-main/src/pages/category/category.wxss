/* 课程分类页面样式 */
.category-container {
  display: flex;
  height: 100vh;
  background: #F8F9FA;
}

/* 顶部搜索栏 */
.search-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB6C1 100%);
  padding: 16rpx 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 16rpx);
}

.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.2);
}

/* CSS搜索图标 */
.search-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-circle {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #999;
  border-radius: 50%;
}

.search-handle {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 14rpx;
  height: 4rpx;
  background: #999;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 左侧分类 */
.category-left {
  width: 160rpx;
  height: 100vh;
  background: #FFFFFF;
  flex-shrink: 0;
  padding-top: 100rpx;
  box-shadow: 2rpx 0 12rpx rgba(0, 0, 0, 0.05);
}

.category-fixed {
  padding: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.search-box-mini {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 24rpx;
  padding: 16rpx;
  transition: all 0.3s;
}

.search-box-mini:active {
  background: #FFE8EE;
}

.search-icon-mini {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.search-circle-sm {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #999;
  border-radius: 50%;
}

.search-handle-sm {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 12rpx;
  height: 3rpx;
  background: #999;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx;
  position: relative;
  transition: all 0.3s;
}

.category-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 0;
  background: #FF6B9D;
  border-radius: 0 3rpx 3rpx 0;
  transition: height 0.3s;
}

.category-item.active .category-indicator {
  height: 60rpx;
}

.category-item.active {
  background: #FFF5F8;
}

.category-name {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  transition: all 0.3s;
}

.category-item.active .category-name {
  color: #FF6B9D;
  font-weight: 600;
  font-size: 28rpx;
}

.category-count {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
  background: #F5F5F5;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

.category-item.active .category-count {
  background: #FFE8EE;
  color: #FF6B9D;
}

/* 右侧内容 */
.category-right {
  flex: 1;
  height: 100vh;
  padding: 110rpx 24rpx 24rpx;
}

/* ========== 筛选区优化 ========== */
.filter-wrapper {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.filter-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.filter-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin: 0 6rpx;
  transition: all 0.25s ease;
  position: relative;
}

.filter-btn:first-child {
  margin-left: 0;
}

.filter-btn:last-child {
  margin-right: 0;
}

.filter-btn.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.3);
}

/* 价格按钮特殊样式 */
.price-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.price-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 16rpx;
  height: 20rpx;
  position: relative;
}

.arrow-up, .arrow-down {
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  position: absolute;
}

.arrow-up {
  border-bottom: 5rpx solid #999;
  top: 0;
  transition: all 0.25s;
}

.arrow-down {
  border-top: 5rpx solid #999;
  bottom: 0;
  transition: all 0.25s;
}

.arrow-up.active {
  border-bottom-color: #FFFFFF;
}

.arrow-down.active {
  border-top-color: #FFFFFF;
}

.price-btn.active .arrow-up {
  border-bottom-color: #FFFFFF;
}

.price-btn.active .arrow-down {
  border-top-color: #FFFFFF;
}

/* 查看全部 */
.view-all {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #FF6B9D;
  padding: 16rpx;
  background: #FFF5F8;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.view-all:active {
  background: #FFE8EE;
}

.arrow {
  font-size: 28rpx;
  font-weight: bold;
}

/* ========== 课程列表优化 ========== */
.course-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #FF6B9D 0%, #FFB6C1 100%);
  border-radius: 4rpx;
}

.section-title text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.course-count {
  font-size: 24rpx;
  color: #999;
  background: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-item {
  display: flex;
  background: #FAFAFA;
  border-radius: 20rpx;
  padding: 16rpx;
  position: relative;
  transition: all 0.3s;
}

.course-item:active {
  background: #F0F0F0;
  transform: scale(0.99);
}

.course-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFE8EE 0%, #FFF5F8 100%);
  flex-shrink: 0;
}

/* 免费标签 */
.free-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.course-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.course-teacher {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.course-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price {
  font-size: 36rpx;
  color: #FF6B9D;
  font-weight: 700;
}

.free {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 600;
}

.original {
  font-size: 24rpx;
  color: #CCC;
  text-decoration: line-through;
}

.course-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rating {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: 600;
}

.count {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-tip text {
  font-size: 30rpx;
  color: #999;
}

.empty-hint {
  font-size: 26rpx !important;
  color: #CCC !important;
}

/* 加载状态 */
.loading {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(255, 255, 255, 0.95);
  padding: 40rpx 60rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #FFE8EE;
  border-top-color: #FF6B9D;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 26rpx;
  color: #666;
}
