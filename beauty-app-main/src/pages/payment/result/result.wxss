/* 支付结果页样式 */
.result-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
}

/* 结果图标 */
.result-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.result-icon.success {
  background: #e8f5e9;
}

.result-icon.fail {
  background: #ffebee;
}

.result-icon image {
  width: 80rpx;
  height: 80rpx;
}

/* 结果标题 */
.result-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 详情区域 */
.result-detail {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.detail-value.highlight {
  color: #FF6B9D;
  font-size: 32rpx;
}

.detail-value.order-id {
  font-size: 24rpx;
  color: #999;
}

/* 提示 */
.result-tips {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 按钮组 */
.button-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 30rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 1;
}

.btn-secondary {
  background: #fff;
  color: #666;
  font-size: 32rpx;
  padding: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #ddd;
  line-height: 1;
}

.btn-primary::after,
.btn-secondary::after {
  display: none;
}
