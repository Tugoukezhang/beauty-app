/* 充值中心样式 */
.recharge-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 顶部用户信息 */
.user-header {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  padding: 40rpx 30rpx;
  text-align: center;
}

.user-coins {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.coins-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
}

.coins-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
}

.user-vip {
  display: flex;
  justify-content: center;
  align-items: center;
}

.vip-status {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
}

.vip-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.vip-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.vip-inactive .vip-text {
  opacity: 0.8;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  position: relative;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #FF6B9D;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #FF6B9D;
  border-radius: 2rpx;
}

/* 内容区域 */
.section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

/* 妆币套餐 */
.coin-packages {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.package-item {
  width: calc(33.333% - 14rpx);
  background: #f8f8f8;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.package-item.selected {
  background: #FFF0F5;
  border-color: #FF6B9D;
}

.package-item.popular {
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4EC 100%);
}

.popular-tag {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  background: #FF6B9D;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 0 16rpx 0 16rpx;
}

.package-coins {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.coin-unit {
  font-size: 24rpx;
  font-weight: normal;
}

.package-bonus {
  font-size: 22rpx;
  color: #FF6B9D;
  background: rgba(255, 107, 157, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}

.package-price {
  font-size: 32rpx;
  color: #FF6B9D;
  font-weight: 600;
}

/* 选中详情 */
.selected-info {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx dashed #eee;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-row.total {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.bonus {
  color: #FF6B9D;
}

.info-value.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B9D;
}

/* 会员套餐 */
.vip-packages {
  display: flex;
  gap: 20rpx;
}

.vip-item {
  flex: 1;
  background: #f8f8f8;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.vip-item.selected {
  background: #FFF0F5;
  border-color: #FF6B9D;
}

.vip-item.popular {
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4EC 100%);
  transform: scale(1.05);
}

.vip-tag {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  background: #FF6B9D;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 0 16rpx 0 16rpx;
}

.vip-duration {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.duration-unit {
  font-size: 24rpx;
  font-weight: normal;
}

.vip-name {
  font-size: 26rpx;
  color: #666;
  margin: 10rpx 0;
}

.vip-price {
  margin-top: 16rpx;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF6B9D;
}

.price-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF6B9D;
}

.vip-original {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-top: 8rpx;
}

/* 会员权益 */
.vip-benefits {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx dashed #eee;
}

.benefits-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.benefits-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
}

.benefit-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}

.benefit-text {
  font-size: 24rpx;
  color: #666;
}

/* 支付方式 */
.payment-section {
  margin-bottom: 20rpx;
}

.payment-methods {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fafafa;
}

.payment-left {
  display: flex;
  align-items: center;
}

.payment-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.payment-name {
  font-size: 30rpx;
  color: #333;
}

.payment-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.payment-check.checked {
  background: #FF6B9D;
  border-color: #FF6B9D;
}

.payment-check image {
  width: 24rpx;
  height: 24rpx;
}

/* 用户协议 */
.agreement-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.agreement-checkbox {
  display: flex;
  align-items: center;
}

.checkbox-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
}

.agreement-link {
  color: #FF6B9D;
}

/* 底部支付栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.pay-label {
  font-size: 28rpx;
  color: #666;
}

.pay-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B9D;
  margin-left: 10rpx;
}

.pay-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  border: none;
  line-height: 1;
}

.pay-btn.loading {
  opacity: 0.7;
}

.pay-btn::after {
  display: none;
}

/* 客服入口 */
.service-section {
  text-align: center;
  padding: 30rpx;
}

.service-text {
  font-size: 24rpx;
  color: #999;
  text-decoration: underline;
}
