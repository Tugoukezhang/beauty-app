/* pages/community/community.wxss */

/* 通用变量 */
page {
  --primary-color: #FF6B9D;
  --secondary-color: #FFB6C1;
  --text-color: #333;
  --text-secondary: #666;
  --text-light: #999;
  --border-color: #F0F0F0;
  --bg-color: #F8F9FA;
  --white: #fff;
  --gradient-primary: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
}

/* 容器 */
.community-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 140rpx;
}

/* ========== 搜索栏 ========== */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--white);
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--bg-color);
  border-radius: 36rpx;
  padding: 0 28rpx;
}

.search-icon-css {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.sc-circle {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #BBB;
  border-radius: 50%;
}

.sc-handle {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 12rpx;
  height: 4rpx;
  background: #BBB;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: var(--text-light);
}

/* ========== Tab栏 ========== */
.tab-bar {
  display: flex;
  background: var(--white);
  padding: 0 40rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 600;
  font-size: 32rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--gradient-primary);
  border-radius: 3rpx;
}

/* ========== 投票Banner ========== */
.vote-banner {
  margin: 20rpx 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFF8FA 0%, #FFFFFF 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 107, 157, 0.15);
  border: 2rpx solid rgba(255, 107, 157, 0.25);
}

.vote-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.vote-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

.vote-icon {
  font-size: 24rpx;
}

.vote-badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.vote-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background: #4CAF50;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1); }
}

.status-text {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: 500;
}

.vote-question {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.vote-options-preview {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.option-tag {
  padding: 8rpx 18rpx;
  background: rgba(255, 107, 157, 0.1);
  color: var(--primary-color);
  font-size: 22rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.vote-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(255, 107, 157, 0.2);
}

.vote-stat {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.vote-count {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 700;
}

.vote-count-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.vote-cta {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.3);
}

.vote-cta .arrow {
  font-size: 28rpx;
}

/* ========== 话题分类栏 ========== */
.topic-bar {
  background: var(--white);
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.topic-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.topic-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  border-radius: 30rpx;
  transition: all 0.25s;
}

.topic-item.active {
  background: rgba(255, 107, 157, 0.12);
  color: var(--primary-color);
  font-weight: 500;
}

/* ========== 排序栏 ========== */
.sort-bar {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  background: var(--white);
  gap: 12rpx;
}

.sort-item {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  border-radius: 24rpx;
  transition: all 0.25s;
}

.sort-item.active {
  background: rgba(255, 107, 157, 0.12);
  color: var(--primary-color);
  font-weight: 500;
}

/* ========== 帖子列表 ========== */
.post-list {
  padding: 20rpx 24rpx;
}

.post-card {
  background: var(--white);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 帖子头部 */
.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #FFE8EE 0%, #FFF5F8 100%);
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 600;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.follow-btn {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: var(--white);
  background: var(--gradient-primary);
  border-radius: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}

.follow-btn.following {
  background: var(--bg-color);
  color: var(--text-secondary);
  box-shadow: none;
}

/* 帖子内容 */
.post-content {
  padding: 0 24rpx 20rpx;
}

.post-text {
  font-size: 30rpx;
  color: var(--text-color);
  line-height: 1.7;
}

.post-text.ellipsis {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.expand-btn {
  color: var(--primary-color);
  font-size: 28rpx;
  margin-left: 8rpx;
  font-weight: 500;
}

/* 图片/视频 */
.post-media {
  display: grid;
  gap: 6rpx;
  padding: 0 24rpx 20rpx;
}

.post-image.single {
  width: 440rpx;
  height: 440rpx;
  border-radius: 20rpx;
}

.post-image.double {
  width: 340rpx;
  height: 340rpx;
  border-radius: 16rpx;
}

.post-image:not(.single):not(.double) {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
}

.video-cover {
  position: relative;
  width: 340rpx;
  height: 340rpx;
  border-radius: 16rpx;
}

.play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon image {
  width: 40rpx;
  height: 40rpx;
}

/* 话题标签 */
.post-topic {
  padding: 0 24rpx 20rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 互动栏 */
.interaction-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.interaction-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
}

.interaction-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.interaction-icon.liked {
  animation: heartBeat 0.3s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.interaction-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: var(--text-light);
}

.no-more {
  color: var(--text-light);
  font-size: 24rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

.publish-btn {
  padding: 22rpx 60rpx;
  background: var(--gradient-primary);
  color: var(--white);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.35);
  border: none;
}

.publish-btn.secondary {
  background: var(--white);
  color: var(--primary-color);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* ========== 话题广场 ========== */
.topic-square-header {
  padding: 32rpx 24rpx 20rpx;
}

.topic-square-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
}

.topic-square {
  padding: 0 24rpx;
}

.topic-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.topic-card {
  background: var(--white);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.topic-cover {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #FFE8EE 0%, #FFF5F8 100%);
}

.topic-info {
  padding: 20rpx;
}

.topic-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.topic-count {
  font-size: 24rpx;
  color: var(--text-light);
}

/* ========== FAB按钮 ========== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 157, 0.45);
}

.fab-icon {
  font-size: 56rpx;
  color: var(--white);
  font-weight: 300;
  line-height: 1;
}
