/* pages/community/publish/publish.wxss */

page {
  --primary-color: #FF6B9D;
  --text-color: #333;
  --text-secondary: #666;
  --text-light: #999;
  --border-color: #eee;
  --bg-color: #f8f8f8;
  --white: #fff;
  background: var(--bg-color);
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background: var(--white);
  border-bottom: 1rpx solid var(--border-color);
}

.nav-cancel {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
}

.nav-submit {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding: 10rpx 20rpx;
  background: rgba(255, 107, 157, 0.1);
  border-radius: 30rpx;
}

.nav-submit.disabled {
  opacity: 0.5;
}

/* 内容区 */
.content-area {
  position: relative;
  background: var(--white);
  padding: 30rpx;
  min-height: 320rpx;
}

.content-input {
  width: 100%;
  min-height: 280rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text-color);
}

.content-count {
  position: absolute;
  right: 30rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 媒体区 */
.media-area {
  background: var(--white);
  padding: 24rpx 30rpx 30rpx;
}

.media-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  position: relative;
  width: 210rpx;
  height: 210rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.media-item image,
.media-item video {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

/* 添加按钮组 */
.add-buttons {
  display: flex;
  gap: 16rpx;
}

.add-btn {
  width: 210rpx;
  height: 210rpx;
  background: var(--bg-color);
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s;
}

.add-btn:active {
  background: #f0f0f0;
  border-color: var(--primary-color);
}

.add-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.add-icon-wrap.video-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.add-icon.video {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.add-text {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 500;
}

.add-hint {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 工具栏 */
.tool-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 20rpx;
  background: var(--white);
  border-top: 1rpx solid var(--border-color);
}

.tool-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 8rpx;
  min-width: 120rpx;
  padding: 10rpx 0;
}

/* 圆圈图标 */
.tool-circle {
  width: 48rpx;
  height: 48rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.tool-circle.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}

.circle-icon {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1;
}

.tool-circle.active .circle-icon {
  color: #fff;
}

.tool-item text {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-item.has-value text {
  color: var(--primary-color);
}

/* 选择器弹窗 */
.picker-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 65vh;
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4rpx 40rpx rgba(0, 0, 0, 0.1);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.picker-close {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 推荐话题区域 */
.recommend-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 30rpx;
  margin-bottom: 16rpx;
}

.section-label.all-topics {
  padding: 24rpx 30rpx 16rpx;
  border-bottom: none;
}

.label-icon {
  font-size: 26rpx;
}

.label-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.recommend-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.recommend-tags {
  display: inline-flex;
  gap: 16rpx;
}

.recommend-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFF0F3 100%);
  border: 2rpx solid rgba(255, 107, 157, 0.2);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  white-space: nowrap;
}

.recommend-tag:first-child {
  margin-left: 6rpx;
}

.recommend-tag.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  color: #fff;
  border-color: transparent;
}

/* 话题列表 */
.picker-list {
  flex: 1;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.picker-item.active {
  background: rgba(255, 107, 157, 0.08);
}

.topic-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
}

.topic-count {
  font-size: 24rpx;
  color: var(--text-light);
  margin-right: 16rpx;
}

.topic-check {
  width: 40rpx;
  height: 40rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

/* 可见性选择 */
.visibility-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.visibility-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.visibility-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.visibility-header {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.visibility-header text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.visibility-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  gap: 24rpx;
}

.visibility-item.active {
  background: rgba(255, 107, 157, 0.08);
}

.visibility-item image {
  width: 48rpx;
  height: 48rpx;
}

.visibility-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.visibility-name {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

.visibility-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

.check-wrap {
  width: 44rpx;
  height: 44rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
}
