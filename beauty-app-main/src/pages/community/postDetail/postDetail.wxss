/* pages/community/postDetail/postDetail.wxss */

page {
  --primary-color: #FF6B9D;
  --text-color: #333;
  --text-secondary: #666;
  --text-light: #999;
  --border-color: #eee;
  --bg-color: #f5f5f5;
  --white: #fff;
  background: var(--bg-color);
  padding-bottom: 120rpx;
}

/* 帖子内容 */
.post-content {
  background: var(--white);
  padding: 30rpx;
}

/* 用户信息 */
.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.follow-btn {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: var(--white);
  background: var(--primary-color);
  border-radius: 30rpx;
}

.follow-btn.following {
  background: var(--bg-color);
  color: var(--text-secondary);
}

/* 文字内容 */
.text-content {
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 30rpx;
  color: var(--text-color);
  line-height: 1.6;
}

/* 图片 */
.media-content {
  display: grid;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.post-image.single {
  width: 480rpx;
  height: 600rpx;
  border-radius: 16rpx;
}

.post-image.double {
  width: 340rpx;
  height: 340rpx;
  border-radius: 16rpx;
}

.post-image:not(.single):not(.double) {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
}

/* 视频 */
.video-content {
  margin-bottom: 24rpx;
}

.video-content video {
  width: 100%;
  border-radius: 16rpx;
}

/* 话题标签 */
.topic-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  background: rgba(255, 107, 157, 0.1);
  border-radius: 20rpx;
}

/* 课程卡片 */
.course-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 24rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
}

.course-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.course-title {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.course-price {
  font-size: 26rpx;
  color: var(--primary-color);
}

.course-btn {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--primary-color);
  background: rgba(255, 107, 157, 0.1);
  border-radius: 20rpx;
}

/* 互动栏 */
.interaction-bar {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.interaction-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
}

.interaction-item .icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.interaction-item .icon.liked {
  animation: heartBeat 0.3s ease;
}

.interaction-item text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

/* 评论区域 */
.comment-section {
  margin-top: 20rpx;
  background: var(--white);
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 30rpx;
}

.comment-count {
  font-size: 26rpx;
  color: var(--text-light);
  font-weight: normal;
}

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  padding-bottom: 30rpx;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-username {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 500;
  margin-right: 16rpx;
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.comment-content {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.reply-to {
  color: var(--primary-color);
}

.reply-user {
  color: var(--primary-color);
}

.comment-actions {
  display: flex;
  align-items: center;
}

.action-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 6rpx;
}

.action-icon.liked {
  animation: heartBeat 0.3s ease;
}

.action-item text {
  font-size: 24rpx;
  color: var(--text-light);
}

.action-item.delete text {
  color: #FF4D4F;
}

/* 空评论 */
.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-comments image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-comments text {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: var(--text-light);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  background: var(--white);
  border-top: 1rpx solid var(--border-color);
  padding-bottom: env(safe-area-inset-bottom);
}

.write-comment {
  display: flex;
  align-items: center;
  width: 45%;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-color);
  border-radius: 36rpx;
}

.write-comment image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.write-comment text {
  font-size: 26rpx;
  color: var(--text-light);
}

.bottom-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  align-items: center;
  margin-left: 32rpx;
}

.action-btn image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 6rpx;
}

.action-btn text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 评论输入框 */
.comment-input-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: var(--white);
  border-top: 1rpx solid var(--border-color);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.input-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.reply-tip {
  font-size: 22rpx;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.input-wrapper input {
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-color);
  border-radius: 36rpx;
  font-size: 28rpx;
}

.submit-btn {
  padding: 16rpx 32rpx;
  margin-left: 20rpx;
  font-size: 28rpx;
  color: var(--white);
  background: var(--primary-color);
  border-radius: 32rpx;
}

.cancel-btn {
  padding: 16rpx 24rpx;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}
