/* 投票页面样式 */

page {
  background: #F7F8FA;
}

.vote-page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ========== 顶部装饰 ========== */
.vote-header {
  position: relative;
  padding: 120rpx 40rpx 80rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 340rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 50%, #FFB6C1 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-tag {
  background: rgba(255, 255, 255, 0.25);
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ========== 投票问题 ========== */
.vote-question-wrap {
  background: #FFFFFF;
  margin: 0 30rpx;
  padding: 36rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 107, 157, 0.1);
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}

.vote-question {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.vote-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vote-stat {
  font-size: 26rpx;
  color: #FF6B9D;
  font-weight: 600;
}

.vote-deadline {
  font-size: 24rpx;
  color: #999;
}

/* ========== 投票选项 ========== */
.vote-options {
  padding: 30rpx;
}

.option-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  overflow: hidden;
}

.option-item.selected {
  border-color: #FF6B9D;
  background: linear-gradient(135deg, #FFF8FA 0%, #FFF0F3 100%);
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 157, 0.18);
}

/* 选项主体 - 水平布局 */
.option-main {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

/* 单选框 */
.option-radio-wrap {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.radio-circle {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #DDD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.radio-circle.checked {
  border-color: #FF6B9D;
  background: #FF6B9D;
}

.radio-dot {
  width: 22rpx;
  height: 22rpx;
  background: #FFFFFF;
  border-radius: 50%;
}

/* 选项内容 */
.option-content {
  flex: 1;
  min-width: 0;
}

.option-label-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-label {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

/* 右侧百分比 */
.option-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.percent-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #999;
  transition: all 0.3s;
}

.percent-num.show {
  color: #FF6B9D;
}

.leading-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF9800 100%);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.leading-badge .badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 进度条 */
.option-progress {
  height: 0rpx;
  background: #F5F5F5;
  overflow: hidden;
  transition: height 0.4s ease;
}

.option-progress.show {
  height: 10rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #FFD1DC 0%, #FFB6C1 100%);
  border-radius: 0 5rpx 5rpx 0;
  transition: width 0.6s ease;
}

.progress-bar.self {
  background: linear-gradient(90deg, #FF6B9D 0%, #FF4757 100%);
}

/* ========== 提交按钮 ========== */
.vote-action {
  padding: 10rpx 30rpx 0;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.4);
  border: none;
}

.submit-btn.disabled {
  background: #E8E8E8;
  color: #999;
  box-shadow: none;
}

.voted-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.voted-icon {
  width: 44rpx;
  height: 44rpx;
  background: #4CAF50;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.voted-tip text:last-child {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

.reshare-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  color: #FF6B9D;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: 3rpx solid #FF6B9D;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 底部规则 ========== */
.vote-rules {
  margin: 40rpx 30rpx 0;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.rules-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rule-num {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 36rpx;
}
