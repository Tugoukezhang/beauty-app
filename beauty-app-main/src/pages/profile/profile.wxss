/* 个人中心页面样式 */
.profile-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* ========== 用户信息区域 ========== */
.user-section {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 50%, #FFB6C1 100%);
  padding: 80rpx 32rpx 40rpx;
  position: relative;
}

/* 未登录 */
.user-info-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 20rpx;
}

.avatar-wrap {
  position: relative;
}

.avatar-default {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 56rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
}

.login-tip {
  margin-top: 20rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* 已登录 */
.user-info-logined {
  padding-bottom: 20rpx;
}

.user-main {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.vip-tag {
  font-size: 28rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.edit-arrow {
  padding: 16rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* VIP横幅 */
.vip-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-top: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 165, 0, 0.3);
}

.vip-banner.vip-unactive {
  background: linear-gradient(135deg, #FFE4B5 0%, #FFDAB9 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 218, 185, 0.3);
}

.vip-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vip-emoji {
  font-size: 40rpx;
}

.vip-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.vip-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.vip-unactive .vip-name {
  color: #8B6914;
}

.vip-expire,
.vip-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.vip-unactive .vip-desc {
  color: #8B6914;
  opacity: 0.7;
}

.vip-btn {
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.3);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.vip-btn-open {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}

/* ========== 数据统计 ========== */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #fff;
  margin: -20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.stat-balance {
  color: #FF6B9D;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* ========== 功能菜单 ========== */
.menu-section {
  margin-top: 20rpx;
}

.menu-group {
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx 0 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-group-title {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  padding: 0 28rpx 16rpx;
}

.menu-row {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0 20rpx;
}

.menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFF0F3 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-emoji {
  font-size: 36rpx;
}

.menu-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 列表式菜单 */
.menu-row-list {
  flex-direction: column;
  padding: 0;
}

.menu-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-list-item:last-child {
  border-bottom: none;
}

.list-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.list-emoji {
  font-size: 32rpx;
}

.list-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.list-arrow {
  font-size: 32rpx;
  color: #ccc;
}
