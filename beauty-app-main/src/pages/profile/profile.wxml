<view class="profile-container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <!-- 未登录状态 -->
    <view class="user-info-login" wx:if="{{!isLogin}}" bindtap="goLogin">
      <view class="avatar-wrap">
        <view class="avatar-default">
          <text class="avatar-icon">👤</text>
        </view>
      </view>
      <view class="login-tip">点击登录</view>
      <text class="login-desc">登录后享受更多服务</text>
    </view>

    <!-- 已登录状态 -->
    <view class="user-info-logined" wx:else>
      <view class="user-main" bindtap="editProfile">
        <view class="avatar-wrap">
          <image class="avatar" src="{{userInfo.avatar || ''}}" mode="aspectFill" wx:if="{{userInfo.avatar}}"></image>
          <view class="avatar-default" wx:else>
            <text class="avatar-icon">👤</text>
          </view>
          <view class="avatar-badge" wx:if="{{isVip}}">VIP</view>
        </view>
        <view class="user-detail">
          <view class="nickname-row">
            <text class="nickname">{{userInfo.nickname || '用户' + userInfo.id}}</text>
            <view class="vip-tag" wx:if="{{isVip}}">👑</view>
          </view>
          <view class="user-id">ID: {{userInfo.id || '10001'}}</view>
        </view>
        <view class="edit-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>

      <!-- VIP横幅 -->
      <view class="vip-banner" wx:if="{{isVip}}" bindtap="becomeVip">
        <view class="vip-left">
          <text class="vip-emoji">👑</text>
          <view class="vip-info">
            <text class="vip-name">VIP会员</text>
            <text class="vip-expire">有效期至 {{vipExpireTime || '2026-12-31'}}</text>
          </view>
        </view>
        <view class="vip-btn">续费</view>
      </view>

      <!-- 成为VIP入口 -->
      <view class="vip-banner vip-unactive" wx:else bindtap="becomeVip">
        <view class="vip-left">
          <text class="vip-emoji">👑</text>
          <view class="vip-info">
            <text class="vip-name">开通VIP会员</text>
            <text class="vip-desc">享受更多特权</text>
          </view>
        </view>
        <view class="vip-btn vip-btn-open">立即开通</view>
      </view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section">
    <view class="stat-item" bindtap="goToPage" data-path="/pages/studyRecord/studyRecord">
      <text class="stat-value">{{stats.courseCount || 0}}</text>
      <text class="stat-label">已购课程</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToPage" data-path="/pages/favorites/favorites">
      <text class="stat-value">{{stats.favoriteCount || 0}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.points || 0}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="recharge">
      <text class="stat-value stat-balance">{{stats.balance || 0}}</text>
      <text class="stat-label">妆币</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 我的订单行 -->
    <view class="menu-group">
      <view class="menu-group-title">我的订单</view>
      <view class="menu-row">
        <view class="menu-item" data-path="/pages/order/order?type=all" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">📋</text>
          </view>
          <text class="menu-name">全部订单</text>
        </view>
        <view class="menu-item" data-path="/pages/order/order?type=unpay" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">💳</text>
          </view>
          <text class="menu-name">待付款</text>
        </view>
        <view class="menu-item" data-path="/pages/order/order?type=unuse" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">📦</text>
          </view>
          <text class="menu-name">待使用</text>
        </view>
        <view class="menu-item" data-path="/pages/order/order?type=refund" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">🔄</text>
          </view>
          <text class="menu-name">退款</text>
        </view>
      </view>
    </view>

    <!-- 会员服务行 -->
    <view class="menu-group">
      <view class="menu-group-title">会员服务</view>
      <view class="menu-row">
        <view class="menu-item" data-path="/pages/favorites/favorites" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">❤️</text>
          </view>
          <text class="menu-name">我的收藏</text>
        </view>
        <view class="menu-item" data-path="/pages/studyRecord/studyRecord" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">📖</text>
          </view>
          <text class="menu-name">学习记录</text>
        </view>
        <view class="menu-item" data-path="/pages/vip/vip" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">👑</text>
          </view>
          <text class="menu-name">会员中心</text>
        </view>
        <view class="menu-item" data-path="/pages/task/task" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">✅</text>
          </view>
          <text class="menu-name">每日任务</text>
        </view>
      </view>
    </view>

    <!-- 资产行 -->
    <view class="menu-group">
      <view class="menu-group-title">我的资产</view>
      <view class="menu-row">
        <view class="menu-item" data-path="/pages/recharge/recharge" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">💰</text>
          </view>
          <text class="menu-name">我的钱包</text>
        </view>
        <view class="menu-item" data-path="/pages/coupon/coupon" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">🎫</text>
          </view>
          <text class="menu-name">优惠券</text>
        </view>
        <view class="menu-item" data-path="/pages/invite/invite" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">🎁</text>
          </view>
          <text class="menu-name">邀请好友</text>
        </view>
        <view class="menu-item" data-path="/pages/recharge/recharge" bindtap="goToPage">
          <view class="menu-icon-wrap">
            <text class="menu-emoji">💎</text>
          </view>
          <text class="menu-name">充值中心</text>
        </view>
      </view>
    </view>

    <!-- 其他行 -->
    <view class="menu-group">
      <view class="menu-group-title">更多</view>
      <view class="menu-row menu-row-list">
        <view class="menu-list-item" data-path="/pages/feedback/feedback" bindtap="goToPage">
          <view class="list-left">
            <text class="list-emoji">💬</text>
            <text class="list-name">意见反馈</text>
          </view>
          <text class="list-arrow">›</text>
        </view>
        <view class="menu-list-item" data-path="/pages/service/service" bindtap="goToPage">
          <view class="list-left">
            <text class="list-emoji">🎧</text>
            <text class="list-name">联系客服</text>
          </view>
          <text class="list-arrow">›</text>
        </view>
        <view class="menu-list-item" data-path="/pages/settings/settings" bindtap="goToPage">
          <view class="list-left">
            <text class="list-emoji">⚙️</text>
            <text class="list-name">设置</text>
          </view>
          <text class="list-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
