/* 课程播放页面样式 */
.course-play-container {
  min-height: 100vh;
  background: #1a1a1a;
}

/* 视频区域 */
.video-section {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: #000;
}

.video-player {
  width: 100%;
  height: 100%;
}

/* 顶部导航 */
.video-nav {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: linear-gradient(180deg, rgba(0,0,0,0.7), transparent);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 48rpx;
  height: 48rpx;
}

.nav-title {
  flex: 1;
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  margin: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-actions {
  display: flex;
  gap: 24rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 章节信息 */
.chapter-info {
  background: #fff;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.chapter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.chapter-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #FFB6C1);
  transition: width 0.3s;
}

/* 播放控制 */
.play-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  background: #fff;
  padding: 32rpx;
  gap: 60rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 26rpx;
}

.control-btn.main {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D, #FFB6C1);
  border-radius: 50%;
  justify-content: center;
}

.control-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 章节列表 */
.chapter-list-section {
  background: #fff;
  padding: 32rpx;
  margin-top: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.chapter-list {
  display: flex;
  flex-direction: column;
}

.chapter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #fafafa;
}

.chapter-item.active {
  background: #FFF5F8;
}

.chapter-item.completed .chapter-num {
  background: #07C160;
  color: #fff;
}

.chapter-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.chapter-num {
  width: 48rpx;
  height: 48rpx;
  background: #f0f0f0;
  color: #999;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.chapter-item.active .chapter-num {
  background: #FF6B9D;
  color: #fff;
}

.chapter-title-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-item.active .chapter-title-text {
  color: #FF6B9D;
  font-weight: 500;
}

.chapter-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chapter-time {
  font-size: 24rpx;
  color: #999;
}

.chapter-status {
  font-size: 24rpx;
  color: #FF6B9D;
}

/* 工具清单面板 */
.tool-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.tool-list {
  background: #fff;
  padding: 0 32rpx 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.tool-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.tool-name {
  font-size: 28rpx;
  color: #333;
}

.tool-recommend {
  font-size: 26rpx;
  color: #FF6B9D;
}

/* 目录面板 */
.catalog-panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 80%;
  background: #fff;
  transform: translateX(100%);
  transition: transform 0.3s;
  z-index: 100;
}

.catalog-panel.show {
  transform: translateX(0);
}

.catalog-list {
  padding: 0 24rpx;
  height: calc(100% - 120rpx);
  overflow-y: auto;
}

.catalog-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.catalog-item.active {
  background: #FFF5F8;
}

.catalog-num {
  width: 40rpx;
  height: 40rpx;
  background: #f0f0f0;
  color: #999;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.catalog-item.active .catalog-num {
  background: #FF6B9D;
  color: #fff;
}

.catalog-title {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.catalog-item.active .catalog-title {
  color: #FF6B9D;
  font-weight: 500;
}

.catalog-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}
