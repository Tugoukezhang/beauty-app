<!-- 用户登录页面 -->
<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-text">i妆</view>
    <text class="app-name">i妆</text>
    <text class="app-slogan">美妆社交 · 约妆服务 · 专业教学</text>
    <text class="app-desc">遇见最美的自己</text>
  </view>

  <!-- 登录方式切换 -->
  <view class="login-tabs">
    <view
      class="tab-item {{loginType === 'phone' ? 'active' : ''}}"
      data-type="phone"
      bindtap="switchLoginType"
    >
      手机号登录
    </view>
    <view
      class="tab-item {{loginType === 'wechat' ? 'active' : ''}}"
      data-type="wechat"
      bindtap="switchLoginType"
    >
      微信登录
    </view>
  </view>

  <!-- 手机号登录表单 -->
  <view class="login-form" wx:if="{{loginType === 'phone'}}">
    <!-- 手机号 -->
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input
        class="form-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 验证码 -->
    <view class="form-item">
      <view class="form-label">验证码</view>
      <view class="code-row">
        <input
          class="form-input code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{verifyCode}}"
          bindinput="onVerifyCodeInput"
        />
        <view
          class="get-code-btn {{countdown > 0 ? 'disabled' : ''}}"
          bindtap="getVerifyCode"
        >
          {{countdown > 0 ? countdownText : '获取验证码'}}
        </view>
      </view>
    </view>

    <!-- 错误提示 -->
    <view class="error-tip" wx:if="{{errorMessage}}">{{errorMessage}}</view>

    <!-- 协议勾选 -->
    <view class="protocol-row">
      <checkbox-group bindchange="onAgreeChange">
        <label class="protocol-label">
          <checkbox value="agree" color="#FF6B9D" />
          <text class="protocol-text">我已阅读并同意</text>
        </label>
      </checkbox-group>
      <text class="protocol-link" bindtap="viewProtocol">《用户协议》</text>
      <text class="protocol-text">和</text>
      <text class="protocol-link" bindtap="viewPrivacy">《隐私政策》</text>
    </view>

    <!-- 登录按钮 -->
    <button
      class="login-btn primary-btn"
      bindtap="phoneLogin"
      loading="{{loading}}"
    >
      登录
    </button>
  </view>

  <!-- 微信登录 -->
  <view class="login-form" wx:if="{{loginType === 'wechat'}}">
    <view class="wechat-tip">点击下方按钮，使用微信快速登录</view>

    <view class="error-tip" wx:if="{{errorMessage}}">{{errorMessage}}</view>

    <button
      class="login-btn wechat-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="wechatLogin"
      loading="{{wechatLoginLoading}}"
    >
      <image class="wechat-icon" src="/assets/icons/icon-wechat.png" />
      微信一键登录
    </button>

    <view class="protocol-row protocol-row-center">
      <text class="protocol-text">登录即表示同意</text>
      <text class="protocol-link" bindtap="viewProtocol">《用户协议》</text>
      <text class="protocol-text">和</text>
      <text class="protocol-link" bindtap="viewPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 调试按钮 -->
  <view class="debug-section" wx:if="{{debugMode}}">
    <button class="debug-btn" bindtap="debugLogin">调试：模拟登录</button>
  </view>
</view>
