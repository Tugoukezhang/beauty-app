/* 登录页面样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFFFFF 100%);
  padding: 120rpx 60rpx 60rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB6C1 100%);
  box-shadow: 0 16rpx 32rpx rgba(255, 107, 157, 0.3);
}

/* i妆 Logo 文字样式 */
.logo-text {
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 96rpx;
  font-weight: 700;
  color: #FF6B9D;
  text-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.4);
  margin-bottom: 8rpx;
  letter-spacing: -2rpx;
}

.app-name {
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 56rpx;
  font-weight: 700;
  color: #FF6B9D;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 8rpx;
  margin-bottom: 60rpx;
}

.tab-item {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  border-radius: 36rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #FF6B9D;
  color: #fff;
  font-weight: 500;
}

/* 登录表单 */
.login-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-color: #FF6B9D;
  background: #fff;
}

.code-row {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
  margin-right: 16rpx;
}

.get-code-btn {
  width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB6C1 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 16rpx;
}

.get-code-btn.disabled {
  background: #e0e0e0;
  color: #999;
}

/* 错误提示 */
.error-tip {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #fff2f0;
  border-radius: 8rpx;
}

/* 协议 */
.protocol-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.protocol-row-center {
  justify-content: center;
}

.protocol-label {
  display: flex;
  align-items: center;
  margin-right: 8rpx;
}

.protocol-text {
  font-size: 24rpx;
  color: #999;
}

.protocol-link {
  font-size: 24rpx;
  color: #FF6B9D;
  margin: 0 4rpx;
}

/* 登录按钮 */
.login-btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 16rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB6C1 100%);
  color: #fff;
  border: none;
}

.wechat-btn {
  background: #07C160;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}

/* 微信提示 */
.wechat-tip {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 48rpx;
}

/* 调试区域 */
.debug-section {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 1rpx dashed #ddd;
}

.debug-btn {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  border: none;
}
