.recommend-page {
  min-height: 100vh;
  background: #FFF5F8;
}
.page-header {
  padding: 30rpx 36rpx;
}
.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #3A1C1A;
}
.coming-soon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.coming-emoji {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}
.coming-text {
  font-size: 32rpx;
  color: #5A3A4A;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.coming-sub {
  font-size: 24rpx;
  color: #9C7A8A;
}
