<view class="favorites-container">
  <!-- Tab切换 -->
  <view class="tabs">
    <view
      class="tab-item {{activeTab === 'course' ? 'active' : ''}}"
      data-tab="course"
      bindtap="switchTab"
    >
      课程收藏
    </view>
    <view
      class="tab-item {{activeTab === 'post' ? 'active' : ''}}"
      data-tab="post"
      bindtap="switchTab"
    >
      帖子收藏
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{empty}}">
    <image class="empty-icon" src="/assets/images/empty-favorite.png" mode="aspectFit" />
    <text class="empty-text">暂无收藏</text>
  </view>

  <!-- 课程收藏列表 -->
  <view class="course-list" wx:elif="{{activeTab === 'course'}}">
    <view
      class="course-item"
      wx:for="{{courseList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToCourse"
    >
      <image class="course-cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="course-info">
        <view class="course-title">{{item.title}}</view>
        <view class="course-teacher">{{item.teacher}}</view>
        <view class="course-meta">
          <text class="course-price">¥{{item.price}}</text>
          <text class="course-original">¥{{item.originalPrice}}</text>
          <text class="course-count">{{item.studyCount}}人学习</text>
        </view>
      </view>
      <view
        class="cancel-btn"
        data-id="{{item.id}}"
        data-type="course"
        catchtap="cancelFavorite"
      >取消</view>
    </view>
  </view>

  <!-- 帖子收藏列表 -->
  <view class="post-list" wx:elif="{{activeTab === 'post'}}">
    <view
      class="post-item"
      wx:for="{{postList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToPost"
    >
      <view class="post-author">
        <image class="author-avatar" src="{{item.author.avatar}}" />
        <text class="author-name">{{item.author.nickname}}</text>
      </view>
      <view class="post-content">{{item.content}}</view>
      <view class="post-images" wx:if="{{item.images.length}}">
        <image
          class="post-image"
          wx:for="{{item.images}}"
          wx:for-item="img"
          src="{{img}}"
          mode="aspectFill"
        />
      </view>
      <view class="post-footer">
        <text class="post-stat">{{item.likes}}赞 · {{item.comments}}评论</text>
        <view
          class="cancel-btn"
          data-id="{{item.id}}"
          data-type="post"
          catchtap="cancelFavorite"
        >取消</view>
      </view>
    </view>
  </view>
</view>
