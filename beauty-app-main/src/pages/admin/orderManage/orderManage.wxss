.order-manage {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: #fff;
  padding: 30rpx 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stat-num.highlight {
  color: #ff6b9d;
}

.stat-num.refund {
  color: #ff4d4f;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx;
  margin-top: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #ff6b9d;
  padding: 0 20rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
}

.filter-item.small {
  padding: 12rpx 16rpx;
}

.filter-value {
  font-size: 24rpx;
  color: #333;
}

.arrow {
  font-size: 18rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 订单列表 */
.order-list {
  height: calc(100vh - 320rpx);
  padding: 0 20rpx;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-no {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.order-status.pending {
  background: #fff7e6;
  color: #faad14;
}

.order-status.paid {
  background: #e6f7e6;
  color: #52c41a;
}

.order-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.order-status.refunded {
  background: #fff1f0;
  color: #ff4d4f;
}

.order-body {
  display: flex;
  justify-content: space-between;
}

.order-info {
  flex: 1;
}

.order-type {
  font-size: 24rpx;
  color: #ff6b9d;
  background: #fff0f3;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}

.order-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.order-user {
  font-size: 24rpx;
  color: #999;
}

.order-amount {
  text-align: right;
}

.amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
  display: block;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  color: #666;
}

.action-btn.refund {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
}

.modal-footer {
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid #eee;
}

.btn-refund {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
}

/* 订单状态栏 */
.order-status-bar {
  text-align: center;
  padding: 40rpx 0;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 30rpx;
}

.order-status-bar.paid {
  background: #e6f7e6;
}

.order-status-bar.pending {
  background: #fff7e6;
}

.order-status-bar.cancelled {
  background: #f5f5f5;
}

.order-status-bar.refunded {
  background: #fff1f0;
}

.status-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

/* 详情区块 */
.detail-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6b9d;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-label {
  font-size: 28rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  color: #333;
}

.item-value.highlight {
  color: #ff4d4f;
  font-weight: 500;
}

.item-value.refund {
  color: #ff4d4f;
}
