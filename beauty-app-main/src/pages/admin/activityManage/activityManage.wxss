.activity-manage-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部操作栏 */
.header-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  border-radius: 12rpx;
  color: #fff;
  font-size: 30rpx;
}

.add-btn .icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 活动列表 */
.activity-list {
  padding: 20rpx;
}

.activity-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.activity-card.ended {
  opacity: 0.7;
}

.activity-cover {
  width: 100%;
  height: 300rpx;
}

.activity-content {
  padding: 24rpx 30rpx;
}

.activity-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-tag.status-0 {
  background: #e3f2fd;
  color: #2196f3;
}

.status-tag.status-1 {
  background: #e8f5e9;
  color: #4caf50;
}

.status-tag.status-2 {
  background: #f5f5f5;
  color: #999;
}

.activity-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.activity-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.meta-item .icon {
  margin-right: 8rpx;
}

.meta-item.type-discount {
  color: #ff6b9d;
  background: #fff0f3;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.meta-item.type-reduce {
  color: #ff9800;
  background: #fff3e0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.meta-item.type-newuser {
  color: #4caf50;
  background: #e8f5e9;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.meta-item.type-recharge {
  color: #9c27b0;
  background: #f3e5f5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.activity-stats {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.activity-actions {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.action-btn.edit {
  background: #e3f2fd;
  color: #2196f3;
}

.action-btn.delete {
  background: #ffebee;
  color: #f44336;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 85%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  max-height: 800rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item .label.required::after {
  content: '*';
  color: #f44336;
  margin-left: 8rpx;
}

.form-item input,
.form-item textarea,
.picker-value {
  width: 100%;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-item textarea {
  height: 160rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value .arrow {
  font-size: 20rpx;
  color: #999;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 封面上传 */
.cover-upload {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-placeholder .icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.upload-placeholder text {
  font-size: 28rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  color: #fff;
}