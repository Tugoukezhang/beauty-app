.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 100rpx;
  left: -100rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
  z-index: 1;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FF6B9D20 0%, #FF8E5320 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  margin-bottom: 40rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.input-label text {
  font-size: 28rpx;
  color: #333;
  margin-left: 12rpx;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.password-wrapper {
  position: relative;
}

.password-wrapper .input-field {
  padding-right: 80rpx;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 10rpx;
}

.hint-text {
  text-align: center;
  margin-bottom: 40rpx;
}

.hint-text text {
  font-size: 24rpx;
  color: #999;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  opacity: 0.7;
}

/* 返回链接 */
.back-link {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.back-link text {
  font-size: 26rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 版权 */
.copyright {
  position: absolute;
  bottom: 40rpx;
  text-align: center;
}

.copyright text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}
