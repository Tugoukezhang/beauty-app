.teacher-manage-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部操作栏 */
.header-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-box .icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 36rpx;
  color: #fff;
  font-size: 26rpx;
}

.add-btn .icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* 老师列表 */
.teacher-list {
  padding: 20rpx;
}

.teacher-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.teacher-header {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.teacher-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
}

.teacher-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.teacher-title {
  font-size: 24rpx;
  color: #667eea;
  background: #f0f2ff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.teacher-intro {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.teacher-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.teacher-tags .tag {
  font-size: 22rpx;
  color: #ff6b9d;
  background: #fff0f3;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-badge.active {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.inactive {
  background: #ffebee;
  color: #f44336;
}

/* 统计数据 */
.teacher-stats {
  display: flex;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-item:not(:last-child) {
  border-right: 1rpx solid #f5f5f5;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-item.highlight .stat-value {
  color: #ff6b9d;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.teacher-actions {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.action-btn.edit {
  background: #e3f2fd;
  color: #2196f3;
}

.action-btn.toggle {
  background: #e8f5e9;
  color: #4caf50;
}

.action-btn.toggle.warning {
  background: #fff3e0;
  color: #ff9800;
}

.action-btn.delete {
  background: #ffebee;
  color: #f44336;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  max-height: 800rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item .label.required::after {
  content: '*';
  color: #f44336;
  margin-left: 8rpx;
}

.form-item input,
.form-item textarea {
  width: 100%;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-item textarea {
  height: 160rpx;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 头像上传 */
.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.avatar-upload image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-placeholder .icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-placeholder text {
  font-size: 24rpx;
  color: #999;
}

/* 复选框和单选框 */
.checkbox-item,
.radio-item {
  display: inline-flex;
  align-items: center;
  margin-right: 30rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}