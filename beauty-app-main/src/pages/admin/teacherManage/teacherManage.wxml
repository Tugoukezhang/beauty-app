<view class="teacher-manage-page">
  <!-- 头部操作栏 -->
  <view class="header-bar">
    <view class="search-box">
      <text class="icon">🔍</text>
      <input type="text" placeholder="搜索老师姓名" />
    </view>
    <view class="add-btn" bindtap="showAddModal">
      <text class="icon">+</text>
      <text>添加老师</text>
    </view>
  </view>

  <!-- 老师列表 -->
  <view class="teacher-list">
    <view class="teacher-card" wx:for="{{teachers}}" wx:key="id">
      <view class="teacher-header">
        <image class="teacher-avatar" src="{{item.avatar}}" mode="aspectFill" />
        <view class="teacher-info">
          <view class="name-row">
            <text class="teacher-name">{{item.name}}</text>
            <text class="teacher-title">{{item.title}}</text>
          </view>
          <text class="teacher-intro">{{item.intro}}</text>
          <view class="teacher-tags">
            <text class="tag" wx:for="{{item.specialty}}" wx:for-item="spec" wx:key="*this">{{spec}}</text>
          </view>
        </view>
        <view class="status-badge {{item.status === 1 ? 'active' : 'inactive'}}">
          {{item.status === 1 ? '在职' : '休息'}}
        </view>
      </view>
      
      <view class="teacher-stats">
        <view class="stat-item">
          <text class="stat-value">{{item.experience}}</text>
          <text class="stat-label">从业经验</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{item.studentCount}}</text>
          <text class="stat-label">学员数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{item.courseCount}}</text>
          <text class="stat-label">课程数</text>
        </view>
        <view class="stat-item highlight">
          <text class="stat-value">¥{{item.coursePrice}}</text>
          <text class="stat-label">课程价格</text>
        </view>
      </view>
      
      <view class="teacher-actions">
        <view class="action-btn edit" bindtap="showEditModal" data-id="{{item.id}}">
          <text>编辑</text>
        </view>
        <view class="action-btn toggle {{item.status === 1 ? 'warning' : ''}}" bindtap="toggleStatus" data-id="{{item.id}}">
          <text>{{item.status === 1 ? '休息' : '在职'}}</text>
        </view>
        <view class="action-btn delete" bindtap="deleteTeacher" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{isEdit ? '编辑老师' : '添加老师'}}</text>
        <text class="close-btn" bindtap="closeModal">×</text>
      </view>
      
      <scroll-view class="modal-body" scroll-y>
        <!-- 头像上传 -->
        <view class="form-item">
          <text class="label required">头像</text>
          <view class="avatar-upload" bindtap="chooseAvatar">
            <image wx:if="{{form.avatar}}" src="{{form.avatar}}" mode="aspectFill" />
            <view wx:else class="upload-placeholder">
              <text class="icon">📷</text>
              <text>点击上传</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="label required">姓名</text>
          <input type="text" value="{{form.name}}" data-field="name" bindinput="onInputChange" placeholder="请输入老师姓名" />
        </view>

        <view class="form-item">
          <text class="label required">职称</text>
          <input type="text" value="{{form.title}}" data-field="title" bindinput="onInputChange" placeholder="如：高级化妆师" />
        </view>

        <view class="form-item">
          <text class="label">从业经验</text>
          <input type="text" value="{{form.experience}}" data-field="experience" bindinput="onInputChange" placeholder="如：5年" />
        </view>

        <view class="form-item">
          <text class="label">课程价格</text>
          <input type="digit" value="{{form.coursePrice}}" data-field="coursePrice" bindinput="onInputChange" placeholder="请输入课程价格" />
        </view>

        <view class="form-item">
          <text class="label">专长领域</text>
          <checkbox-group bindchange="onSpecialtyChange">
            <label class="checkbox-item" wx:for="{{specialtyOptions}}" wx:key="*this">
              <checkbox value="{{item}}" checked="{{form.specialty.includes(item)}}" />
              <text>{{item}}</text>
            </label>
          </checkbox-group>
        </view>

        <view class="form-item">
          <text class="label">个人简介</text>
          <textarea value="{{form.intro}}" data-field="intro" bindinput="onInputChange" placeholder="请输入个人简介" maxlength="200" />
          <text class="word-count">{{form.intro.length}}/200</text>
        </view>

        <view class="form-item">
          <text class="label">状态</text>
          <radio-group bindchange="onStatusChange">
            <label class="radio-item" wx:for="{{statusOptions}}" wx:key="value">
              <radio value="{{item.value}}" checked="{{form.status === item.value}}" />
              <text>{{item.label}}</text>
            </label>
          </radio-group>
        </view>
      </scroll-view>
      
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="saveTeacher">保存</button>
      </view>
    </view>
  </view>
</view>