<view class="user-manage">
  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">总用户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num highlight">{{stats.today}}</text>
      <text class="stat-label">今日新增</text>
    </view>
    <view class="stat-card">
      <text class="stat-num vip">{{stats.vip}}</text>
      <text class="stat-label">会员数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num active">{{stats.active}}</text>
      <text class="stat-label">活跃用户</text>
    </view>
  </view>

  <!-- 搜索和筛选 -->
  <view class="filter-bar">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="搜索用户昵称/手机号" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <text class="search-btn" bindtap="onSearch">搜索</text>
    </view>
    <view class="filter-row">
      <picker mode="selector" range="{{statusList}}" bindchange="onStatusChange">
        <view class="filter-item">
          <text class="filter-label">状态</text>
          <text class="filter-value">{{statusFilter ? (statusFilter === 'active' ? '正常' : '禁用') : '全部'}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
      <picker mode="selector" range="{{vipList}}" bindchange="onVipChange">
        <view class="filter-item">
          <text class="filter-label">身份</text>
          <text class="filter-value">{{vipFilter === '' ? '全部' : (vipFilter ? '会员' : '普通')}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 用户列表 -->
  <scroll-view class="user-list" scroll-y bindscrolltolower="onLoadMore">
    <view class="user-item" wx:for="{{users}}" wx:key="_id" data-user="{{item}}" bindtap="showUserDetail">
      <image class="user-avatar" src="{{item.avatarUrl || 'https://picsum.photos/100/100?random=avatar'}}" mode="aspectFill"/>
      <view class="user-info">
        <view class="user-header">
          <text class="user-name">{{item.nickName || '未设置昵称'}}</text>
          <view class="user-tags">
            <text class="tag vip" wx:if="{{item.isVip}}">会员</text>
            <text class="tag status {{item.status}}">{{item.status === 'active' ? '正常' : '禁用'}}</text>
          </view>
        </view>
        <text class="user-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
        <view class="user-meta">
          <text class="meta-item">妆币: {{item.coins || 0}}</text>
          <text class="meta-item">课程: {{item.courseCount || 0}}</text>
          <text class="meta-item">{{item.createTime}}</text>
        </view>
      </view>
      <view class="user-actions" catchtap="stopPropagation">
        <text class="action-btn" data-id="{{item._id}}" data-status="{{item.status}}" bindtap="toggleUserStatus">
          {{item.status === 'active' ? '禁用' : '启用'}}
        </text>
        <text class="action-btn vip" data-id="{{item._id}}" bindtap="giveVip">送会员</text>
        <text class="action-btn coin" data-id="{{item._id}}" bindtap="giveCoins">送妆币</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && users.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty" wx:if="{{!loading && users.length === 0}}">
      <text class="empty-icon">👥</text>
      <text class="empty-text">暂无用户</text>
    </view>
  </scroll-view>

  <!-- 用户详情弹窗 -->
  <view class="modal {{showDetailModal ? 'show' : ''}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">用户详情</text>
        <text class="modal-close" bindtap="closeModal">×</text>
      </view>
      
      <scroll-view class="modal-body" scroll-y wx:if="{{selectedUser}}">
        <view class="user-profile">
          <image class="profile-avatar" src="{{selectedUser.avatarUrl || 'https://picsum.photos/100/100?random=avatar'}}"/>
          <text class="profile-name">{{selectedUser.nickName || '未设置昵称'}}</text>
          <view class="profile-tags">
            <text class="profile-tag vip" wx:if="{{selectedUser.isVip}}">会员</text>
            <text class="profile-tag status {{selectedUser.status}}">{{selectedUser.status === 'active' ? '正常' : '禁用'}}</text>
          </view>
        </view>

        <view class="detail-section">
          <view class="section-title">基本信息</view>
          <view class="detail-item">
            <text class="item-label">用户ID</text>
            <text class="item-value">{{selectedUser._id}}</text>
          </view>
          <view class="detail-item">
            <text class="item-label">手机号</text>
            <text class="item-value">{{selectedUser.phone || '未绑定'}}</text>
          </view>
          <view class="detail-item">
            <text class="item-label">注册时间</text>
            <text class="item-value">{{selectedUser.createTime}}</text>
          </view>
          <view class="detail-item">
            <text class="item-label">最后登录</text>
            <text class="item-value">{{selectedUser.lastLoginTime || '-'}}</text>
          </view>
        </view>

        <view class="detail-section">
          <view class="section-title">资产信息</view>
          <view class="detail-item">
            <text class="item-label">妆币余额</text>
            <text class="item-value highlight">{{selectedUser.coins || 0}}</text>
          </view>
          <view class="detail-item">
            <text class="item-label">会员状态</text>
            <text class="item-value">{{selectedUser.isVip ? '会员' : '普通用户'}}</text>
          </view>
          <view class="detail-item" wx:if="{{selectedUser.isVip}}">
            <text class="item-label">会员到期</text>
            <text class="item-value">{{selectedUser.vipExpireTime || '-'}}</text>
          </view>
        </view>

        <view class="detail-section">
          <view class="section-title">行为数据</view>
          <view class="detail-item">
            <text class="item-label">购买课程</text>
            <text class="item-value">{{selectedUser.courseCount || 0}} 门</text>
          </view>
          <view class="detail-item">
            <text class="item-label">发布帖子</text>
            <text class="item-value">{{selectedUser.postCount || 0}} 篇</text>
          </view>
          <view class="detail-item">
            <text class="item-label">累计消费</text>
            <text class="item-value">¥{{selectedUser.totalSpend || 0}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeModal">关闭</button>
      </view>
    </view>
  </view>
</view>
