<view class="data-stats-page">
  <!-- 时间选择器 -->
  <view class="date-selector">
    <picker mode="selector" range="{{dateRangeOptions}}" range-key="label" value="{{dateRangeIndex}}" bindchange="onDateRangeChange">
      <view class="date-picker">
        <text class="date-label">{{dateRangeLabel}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
    <view class="refresh-btn" bindtap="onRefresh">
      <text class="icon">🔄</text>
    </view>
  </view>

  <!-- 核心数据卡片 -->
  <view class="core-stats">
    <view class="stat-card">
      <text class="stat-value">{{coreStats.newUsers}}</text>
      <text class="stat-label">新增用户</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{coreStats.activeUsers}}</text>
      <text class="stat-label">活跃用户</text>
    </view>
    <view class="stat-card highlight">
      <text class="stat-value">¥{{coreStats.totalRevenue}}</text>
      <text class="stat-label">总收入</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{coreStats.totalOrders}}</text>
      <text class="stat-label">订单数</text>
    </view>
  </view>

  <!-- 收入构成 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">收入构成</text>
    </view>
    <view class="revenue-breakdown">
      <view class="revenue-item">
        <view class="revenue-icon course">📚</view>
        <view class="revenue-info">
          <text class="revenue-label">课程销售</text>
          <text class="revenue-value">¥{{coreStats.courseSales}}</text>
        </view>
        <text class="revenue-percent">{{courseSalesPercent}}%</text>
      </view>
      <view class="revenue-item">
        <view class="revenue-icon vip">👑</view>
        <view class="revenue-info">
          <text class="revenue-label">会员收入</text>
          <text class="revenue-value">¥{{coreStats.vipSales}}</text>
        </view>
        <text class="revenue-percent">{{vipSalesPercent}}%</text>
      </view>
    </view>
  </view>

  <!-- 数据趋势 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">数据趋势</text>
    </view>
    <view class="trend-chart">
      <view class="chart-legend">
        <view class="legend-item">
          <view class="legend-dot blue"></view>
          <text>新增用户</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot green"></view>
          <text>活跃用户</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot orange"></view>
          <text>收入</text>
        </view>
      </view>
      <view class="chart-placeholder">
        <text class="placeholder-text">📊 趋势图表区域</text>
        <text class="placeholder-sub">（集成图表库后显示）</text>
      </view>
    </view>
  </view>

  <!-- 课程销售排行 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">课程销售TOP5</text>
    </view>
    <view class="ranking-list">
      <view class="ranking-item" wx:for="{{courseRanking}}" wx:key="id">
        <view class="rank-number {{index < 3 ? 'top' : ''}}">{{index + 1}}</view>
        <view class="rank-info">
          <text class="rank-title">{{item.title}}</text>
          <text class="rank-sales">销量 {{item.sales}}</text>
        </view>
        <text class="rank-revenue">¥{{item.revenue}}</text>
      </view>
    </view>
  </view>

  <!-- 用户画像 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">用户画像</text>
    </view>
    <view class="profile-section">
      <view class="profile-title">性别分布</view>
      <view class="profile-bars">
        <view class="profile-bar">
          <text class="bar-label">👩 女 {{userProfile.gender.female}}%</text>
          <view class="bar-track">
            <view class="bar-fill female" style="width: {{userProfile.gender.female}}%"></view>
          </view>
        </view>
        <view class="profile-bar">
          <text class="bar-label">👨 男 {{userProfile.gender.male}}%</text>
          <view class="bar-track">
            <view class="bar-fill male" style="width: {{userProfile.gender.male}}%"></view>
          </view>
        </view>
      </view>
    </view>
    <view class="profile-section">
      <view class="profile-title">年龄分布</view>
      <view class="age-grid">
        <view class="age-item" wx:for="{{userProfile.age}}" wx:for-item="percent" wx:for-index="range">
          <text class="age-range">{{range}}岁</text>
          <text class="age-percent">{{percent}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 导出按钮 -->
  <view class="export-section">
    <button class="export-btn" bindtap="onExportReport">导出数据报表</button>
  </view>
</view>