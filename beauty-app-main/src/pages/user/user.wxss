/* pages/user/user.wxss */

page {
  --primary-color: #FF6B9D;
  --text-color: #333;
  --text-secondary: #666;
  --text-light: #999;
  --border-color: #eee;
  --bg-color: #f5f5f5;
  --white: #fff;
  background: var(--bg-color);
}

/* ========== 用户头部 ========== */
.user-header {
  position: relative;
  background: var(--white);
  padding-bottom: 0;
}

.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 50%, #FFB6C1 100%);
}

/* 设置按钮 */
.header-actions {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 30rpx 0;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 28rpx;
}

/* 用户信息 */
.user-info-section {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-default {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 64rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
}

.avatar-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
}

.user-detail {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.username {
  font-size: 36rpx;
  color: var(--text-color);
  font-weight: 700;
}

.vip-tag {
  font-size: 28rpx;
}

.user-bio {
  font-size: 26rpx;
  color: var(--text-secondary);
  max-width: 500rpx;
  text-align: center;
  line-height: 1.5;
}

/* 操作按钮 */
.action-btns {
  margin-bottom: 28rpx;
}

.edit-btn,
.follow-btn,
.following-btn {
  padding: 14rpx 56rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
  border: none;
}

.edit-btn {
  color: var(--text-color);
  background: #f5f5f5;
}

.follow-btn {
  color: #fff;
  background: linear-gradient(135deg, #FF6B9D, #FF8FAB);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.3);
}

.following-btn {
  color: var(--text-secondary);
  background: #f5f5f5;
  border: 1rpx solid #eee;
}

/* 数据统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 34rpx;
  color: var(--text-color);
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

/* ========== Tab栏 ========== */
.tab-bar {
  display: flex;
  background: var(--white);
  border-bottom: 1rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-indicator {
  width: 48rpx;
  height: 6rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
  position: absolute;
  bottom: 0;
}

/* ========== 内容区域 ========== */
.content-area {
  padding: 16rpx;
}

/* 笔记网格 */
.post-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.grid-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.grid-item image {
  width: 100%;
  aspect-ratio: 1;
  display: block;
}

.grid-placeholder {
  width: 100%;
  aspect-ratio: 1;
  background: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48rpx;
}

.item-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 16rpx;
}

.heart-icon {
  font-size: 22rpx;
}

.like-num {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 课程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.course-cover-wrap {
  position: relative;
  width: 220rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.course-cover {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  background: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.course-free-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.course-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.course-title {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.course-desc {
  font-size: 24rpx;
  color: var(--text-light);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: auto;
}

.course-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.course-price {
  font-size: 30rpx;
  color: var(--primary-color);
  font-weight: 700;
}

.course-price.free {
  color: #4CAF50;
}

.course-students {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  grid-column: 1 / -1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-light);
}
